      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "## Task 1: Mark all launch sites on a map\n# Create a map centered at an average coordinate\nnasa_map = folium.Map(location=[spacex_df['Lat'].mean(), spacex_df['Long'].mean()], zoom_start=5)\n\n# Get unique launch sites\nlaunch_sites = spacex_df[['Launch Site', 'Lat', 'Long']].drop_duplicates()\n\n# Add markers for each launch site\nfor _, row in launch_sites.iterrows():\n    folium.Marker(\n        location=[row['Lat'], row['Long']],\n        popup=row['Launch Site']\n    ).add_to(nasa_map)\n\nfrom IPython.display import HTML\n\nHTML(nasa_map._repr_html_())",
